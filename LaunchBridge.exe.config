<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup useLegacyV2RuntimeActivationPolicy="true">
    <supportedRuntime version="v4.0" />
  </startup>
  <appSettings>
    <add key="EnableWindowsFormsHighDpiAutoResizing" value="true" />
  </appSettings>
  <runtime>
    <AppContextSwitchOverrides value="Switch.System.Windows.Forms.DisableDpiChangedMessageHandling=false;Switch.System.Windows.Forms.DoNotSupportDpiChanges=false;Switch.System.Windows.Forms.EnableSinglePassScalingOfDpiForms=true" />
  </runtime>
</configuration>
