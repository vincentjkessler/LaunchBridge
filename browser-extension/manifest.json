{
  "manifest_version": 3,
  "name": "LaunchBridge Smart Click",
  "version": "0.2.0",
  "description": "Reliably detects completed AI downloads and sends supported app packages to LaunchBridge.",
  "key": "",
  "permissions": [
    "downloads",
    "nativeMessaging",
    "notifications",
    "storage"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://gemini.google.com/*",
    "https://claude.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://claude.ai/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "LaunchBridge Smart Click"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}