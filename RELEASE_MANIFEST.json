{
  "ProductId": "devmind-launchbridge",
  "Version": "0.3.1",
  "ReleaseChannel": "stable",
  "PrimaryChange": "Smart Click reliability fix",
  "StatePreservedDuringUpdate": [
    "%LOCALAPPDATA%/DevMind/LaunchBridge/config.json",
    "logs",
    "rollbacks",
    "browser profiles",
    "installed-product records",
    "extension profiles",
    "extension icons"
  ],
  "CompatibilityNote": "Installs in place over 0.2.5 and preserves extension profiles, icons, associations, settings, and installed apps.",
  "Rollback": "The existing executable is not stopped or replaced unless Windows C# compilation succeeds.",
  "Branding": {
    "VisibleApplicationName": "LaunchBridge",
    "Executable": "LaunchBridge.exe",
    "Header": "LAUNCHBRIDGE",
    "LegacyExecutableRemoved": true,
    "LegacyShortcutsMigrated": true,
    "LegacyStartupAndAssociationsRemoved": true
  },
  "DpiRendering": {
    "Manifest": "PerMonitorV2,PerMonitor",
    "RuntimeInitialization": "SetProcessDpiAwarenessContext before WinForms with SetProcessDPIAware fallback",
    "WinFormsAutoScaleMode": "Dpi",
    "BaselineDpi": 96,
    "OrdinaryControlTextRendering": "GDI/ClearType compatible",
    "RuntimeConfig": "LaunchBridge.exe.config enables WinForms high-DPI resizing and DPI-change handling"
  },
  "TurboLaunchRetained": true,
  "AutomaticLifecycleCleanupRetained": true,
  "StopAllRetained": true,
  "RuntimeStatusAccuracyRetained": true,
  "DefaultTab": "Extensions",
  "HomeTabRemoved": true,
  "ScrollableTabs": [
    "Activity",
    "Installed Products",
    "Error Cockpit",
    "Logs",
    "Settings"
  ],
  "CompilerPreflight": "LaunchBridgeCore now defines the helper required by all smart-package relative-path call sites; target Windows csc compile remains compile-before-replace.",
  "PackageBuilderTab": "Removed",
  "ExtensionProfiles": {
    "MigrationFromRegisteredExtensions": true,
    "ImmediateAiPrompt": true,
    "FullShortAndIconPrompts": true,
    "RasterAndIcoImport": true,
    "WindowsAssociationIcon": true,
    "ProfileFilesStoredLocally": true
  },
  "SmartPackages": {
    "ManifestRequired": false,
    "FilenameConvention": "<ProductName>_v<Version>.<extension>",
    "OuterFolderTolerance": true,
    "EntryPointDetection": [
      "remembered target",
      "matching EXE",
      "packaged EXE",
      "CMD/BAT/PowerShell",
      "complete Node/Electron",
      "index.html"
    ],
    "TurboLaunchFingerprinting": true
  },
  "AdvancedManifestPackagesRetained": true,
  "OpenSourceReady": {
    "License": "MIT",
    "ContributionGuide": true,
    "PackageSpecification": true,
    "ExtensionProfileSpecification": true
  },
  "TabOrder": [
    "Extensions",
    "Activity",
    "Error Cockpit",
    "Installed Products",
    "Settings",
    "Logs"
  ],
  "SmartClick": {
    "BrowserExtensionId": "lkjjnhlhobcpmhpgkmkbgjioclgohjdk",
    "NativeHost": "com.launchbridge.smartclick",
    "ApprovedSites": [
      "chatgpt.com",
      "gemini.google.com",
      "claude.ai"
    ],
    "Setup": "One-time unpacked extension load",
    "NormalZipSupport": true,
    "ExtensionVersion": "0.2.0",
    "Reliability": "Persistent transaction state, retroactive matching, referrer fallback, and native ping test"
  }
}